@model List<DOTNETCORE_DEV.Models.IncidentAssignment>
@{
    ViewData["Title"] = "ประวัติการส่งต่อ";
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-shield-exclamation"></i>
                ระบบจัดการเหตุการณ์ - ก.ล.ต.
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-house"></i> หน้าแรก
                </a>
                <a class="nav-link text-white" href="@Url.Action("Index", "IncidentAssignment")">
                    <i class="bi bi-person-plus"></i> Assign Incident
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-clock-history"></i> ประวัติการส่งต่อ Incident
                            @if (ViewBag.Incident != null)
                            {
                                <span class="badge bg-primary ms-2">#@ViewBag.Incident.IncidentId</span>
                            }
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.Incident != null)
                        {
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <h6>รายละเอียดเหตุการณ์</h6>
                                    <p><strong>ปัญหา:</strong> @ViewBag.Incident.Problem</p>
                                    <p><strong>วันที่รับแจ้ง:</strong> @ViewBag.Incident.Date.ToShortDateString()</p>
                                    <p><strong>สถานะ:</strong> @ViewBag.Incident.Result</p>
                                </div>
                                <div class="col-md-6">
                                    <h6>ข้อมูลผู้แจ้ง</h6>
                                    <p><strong>ชื่อ:</strong> @ViewBag.Incident.Name</p>
                                    <p><strong>อีเมล:</strong> @ViewBag.Incident.Email</p>
                                    <p><strong>ประเภทบริการ:</strong> @ViewBag.Incident.ServiceType?.serviceTypesName</p>
                                </div>
                            </div>
                        }

                        @if (Model != null && Model.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>ลำดับ</th>
                                            <th>ส่งโดย</th>
                                            <th>ส่งให้</th>
                                            <th>ประเภทการส่ง</th>
                                            <th>วันที่ส่ง</th>
                                            <th>สถานะ</th>
                                            <th>หมายเหตุ</th>
                                            <th>วันที่ยอมรับ</th>
                                            <th>วันที่เสร็จสิ้น</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Count; i++)
                                        {
                                            var assignment = Model[i];
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>
                                                    <div>
                                                        <strong>@assignment.AssignedByEmployee?.Name</strong>
                                                        <br>
                                                        <small class="text-muted">
                                                            @(assignment.AssignedByEmployee?.SupportLevel == 1 ? "1st Level" : "2nd Level")
                                                        </small>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div>
                                                        <strong>@assignment.AssignedToEmployee?.Name</strong>
                                                        <br>
                                                        <small class="text-muted">
                                                            @(assignment.AssignedToEmployee?.SupportLevel == 1 ? "1st Level" : "2nd Level")
                                                        </small>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="badge bg-info">
                                                        @assignment.AssignmentType
                                                    </span>
                                                </td>
                                                <td>@assignment.AssignedDateTime.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    <span class="badge bg-@(assignment.AssignmentStatus == "Assigned" ? "primary" : assignment.AssignmentStatus == "Accepted" ? "success" : assignment.AssignmentStatus == "Completed" ? "secondary" : "danger")">
                                                        @assignment.AssignmentStatus
                                                    </span>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(assignment.AssignmentNotes))
                                                    {
                                                        <small>@assignment.AssignmentNotes</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (assignment.AcceptedDateTime.HasValue)
                                                    {
                                                        <small>@assignment.AcceptedDateTime.Value.ToString("dd/MM HH:mm")</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (assignment.CompletedDateTime.HasValue)
                                                    {
                                                        <small>@assignment.CompletedDateTime.Value.ToString("dd/MM HH:mm")</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                <p class="mt-2">ยังไม่มีประวัติการส่งต่อสำหรับเหตุการณ์นี้</p>
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <a href="@Url.Action("Index", "IncidentAssignment")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> กลับหน้า Assign
                            </a>
                            @if (ViewBag.Incident != null)
                            {
                                <a href="@Url.Action("Create", "IncidentAssignment", new { incidentId = ViewBag.Incident.IncidentId })" class="btn btn-primary">
                                    <i class="bi bi-plus"></i> ส่งต่ออีกครั้ง
                                </a>
                                <a href="@Url.Action("Details", "Home", new { id = ViewBag.Incident.IncidentId })" class="btn btn-info">
                                    <i class="bi bi-eye"></i> ดูรายละเอียด Incident
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
