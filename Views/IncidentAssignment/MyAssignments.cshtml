@model List<DOTNETCORE_DEV.Models.IncidentAssignment>
@{
    ViewData["Title"] = "งานที่รับผิดชอบ";
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-shield-exclamation"></i>
                ระบบจัดการเหตุการณ์ - ก.ล.ต.
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-house"></i> หน้าแรก
                </a>
                <a class="nav-link text-white" href="@Url.Action("Index", "IncidentAssignment")">
                    <i class="bi bi-person-plus"></i> Assign Incident
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person-workspace"></i> งานที่รับผิดชอบ
                            @if (ViewBag.Employee != null)
                            {
                                <span class="badge bg-primary ms-2">@ViewBag.Employee.Name</span>
                                <span class="badge bg-info ms-1">@(ViewBag.Employee.SupportLevel == 1 ? "1st Level" : "2nd Level")</span>
                            }
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (Model != null && Model.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Incident</th>
                                            <th>ปัญหา</th>
                                            <th>ส่งโดย</th>
                                            <th>วันที่ส่ง</th>
                                            <th>Priority</th>
                                            <th>สถานะ</th>
                                            <th>หมายเหตุ</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var assignment in Model)
                                        {
                                            <tr>
                                                <td>
                                                    <a href="@Url.Action("Details", "Home", new { id = assignment.IncidentId })">
                                                        #@assignment.IncidentId
                                                    </a>
                                                </td>
                                                <td>
                                                    <small>@assignment.Incident?.Problem.Substring(0, Math.Min(50, assignment.Incident?.Problem.Length ?? 0))...</small>
                                                </td>
                                                <td>@assignment.AssignedByEmployee?.Name</td>
                                                <td>@assignment.AssignedDateTime.ToString("dd/MM HH:mm")</td>
                                                <td>
                                                    <span class="badge bg-@(assignment.Priority == 1 ? "danger" : assignment.Priority == 2 ? "warning" : assignment.Priority == 3 ? "info" : "secondary")">
                                                        Priority @assignment.Priority
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-@(assignment.AssignmentStatus == "Assigned" ? "primary" : assignment.AssignmentStatus == "Accepted" ? "success" : assignment.AssignmentStatus == "Completed" ? "secondary" : "danger")">
                                                        @assignment.AssignmentStatus
                                                    </span>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(assignment.AssignmentNotes))
                                                    {
                                                        <small>@assignment.AssignmentNotes</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        @if (assignment.AssignmentStatus == "Assigned")
                                                        {
                                                            <form asp-action="AcceptAssignment" method="post" style="display: inline;">
                                                                <input type="hidden" name="assignmentId" value="@assignment.AssignmentId" />
                                                                <button type="submit" class="btn btn-success" title="ยอมรับ">
                                                                    <i class="bi bi-check"></i>
                                                                </button>
                                                            </form>
                                                            <form asp-action="RejectAssignment" method="post" style="display: inline;">
                                                                <input type="hidden" name="assignmentId" value="@assignment.AssignmentId" />
                                                                <input type="hidden" name="rejectionReason" value="ไม่สามารถรับผิดชอบได้" />
                                                                <button type="submit" class="btn btn-danger" title="ปฏิเสธ">
                                                                    <i class="bi bi-x"></i>
                                                                </button>
                                                            </form>
                                                        }
                                                        @if (assignment.AssignmentStatus == "Accepted")
                                                        {
                                                            <a href="@Url.Action("Index", "AssignmentResolution", new { assignmentId = assignment.AssignmentId })" class="btn btn-primary" title="บันทึกการแก้ไข">
                                                                <i class="bi bi-clipboard-plus"></i>
                                                            </a>
                                                            <a href="@Url.Action("Create", "AssignmentResolution", new { assignmentId = assignment.AssignmentId })" class="btn btn-info" title="แก้ไขปัญหาใหม่">
                                                                <i class="bi bi-tools"></i>
                                                            </a>
                                                            <form asp-action="CompleteAssignment" method="post" style="display: inline;">
                                                                <input type="hidden" name="assignmentId" value="@assignment.AssignmentId" />
                                                                <button type="submit" class="btn btn-secondary" title="เสร็จสิ้น">
                                                                    <i class="bi bi-check2"></i>
                                                                </button>
                                                            </form>
                                                        }
                                                        <a href="@Url.Action("History", "IncidentAssignment", new { incidentId = assignment.IncidentId })" class="btn btn-outline-info" title="ดูประวัติ">
                                                            <i class="bi bi-clock-history"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                <p class="mt-2">ไม่มีงานที่รับผิดชอบในขณะนี้</p>
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <a href="@Url.Action("Index", "IncidentAssignment")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> กลับหน้า Assign
                            </a>
                            @if (ViewBag.Employee != null)
                            {
                                <a href="@Url.Action("MyAssignments", "IncidentAssignment", new { employeeId = ViewBag.Employee.EmployeeID })" class="btn btn-outline-primary">
                                    <i class="bi bi-arrow-clockwise"></i> รีเฟรช
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
