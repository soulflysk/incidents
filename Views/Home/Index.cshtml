@{
    var statusFilter = ViewData["StatusFilter"]?.ToString();
    var serviceTypeFilter = ViewData["ServiceTypeFilter"]?.ToString();
    var currentPage = (int)ViewData["CurrentPage"];
    var totalPages = (int)ViewData["TotalPages"];
}

@model IEnumerable<DOTNETCORE_DEV.Models.Incident>
@{
    ViewData["Title"] = "รายการเหตุการณ์ทั้งหมด";
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-shield-exclamation"></i>
                ระบบจัดการเหตุการณ์ - ก.ล.ต.
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" href="@Url.Action("Create", "Home")">
                    <i class="bi bi-plus-circle"></i> บันทึกเหตุการณ์ใหม่
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-list-ul"></i> รายการเหตุการณ์ทั้งหมด
                        </h5>
                        <div>
                            <a href="@Url.Action("Create", "Home")" class="btn btn-success btn-sm">
                                <i class="bi bi-plus-circle"></i> เหตุการณ์ใหม่
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <!-- Filters -->
                        <form method="get" class="row mb-3">
                            <div class="col-md-3">
                                <label class="form-label">ค้นหา</label>
                                <input type="text" class="form-control" name="search" value="@ViewData["Search"]" placeholder="ค้นหาเลขที่เหตุการณ์, ผู้แจ้ง...">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">สถานะ</label>
                                <select class="form-select" name="statusFilter">
                                    <option value="">ทั้งหมด</option>
                                    @{
                                        var statuses = new[] { "รับแจ้ง", "ดำเนินการ", "รอดำเนินการ", "แก้ไขแล้ว", "ปิดเรื่อง" };
                                        foreach (var status in statuses)
                                        {
                                            var selected = statusFilter == status ? "selected" : "";
                                            <option value="@status" selected="@selected">@status</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">ประเภทบริการ</label>
                                <select class="form-select" name="serviceTypeFilter">
                                    <option value="">ทั้งหมด</option>
                                    @if (ViewBag.ServiceTypes != null)
                                    {
                                        @foreach (var service in ViewBag.ServiceTypes)
                                        {
                                            var selected = serviceTypeFilter == service.serviceTypesName ? "selected" : "";
                                            <option value="@service.serviceTypesName" selected="@selected">@service.serviceTypesName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">วันที่รับแจ้ง</label>
                                <input type="date" class="form-control" name="filterDate">
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-funnel"></i> กรอง
                                </button>
                            </div>
                        </form>

                        <!-- Incident Table -->
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>เลขที่เหตุการณ์</th>
                                        <th>วันที่รับแจ้ง</th>
                                        <th>ผู้แจ้ง</th>
                                        <th>ประเภทบริการ</th>
                                        <th>ปัญหา</th>
                                        <th>สถานะ</th>
                                        <th>การดำเนินการ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        @foreach (var incident in Model)
                                        {
                                            <tr>
                                                <td><span class="badge bg-info">@incident.IncidentId</span></td>
                                                <td>@incident.Date</td>
                                                <td>
                                                    @if (incident.InsideOrOutside == "ภายใน ก.ล.ต.")
                                                    {
                                                        @incident.Employee?.Name
                                                    }
                                                    else
                                                    {
                                                        @incident.Name
                                                    }
                                                </td>
                                                <td>@incident.ServiceType?.serviceTypesName</td>
                                                <td>@(incident.Problem?.Length > 50 ? incident.Problem.Substring(0, 50) + "..." : incident.Problem)</td>
                                                <td>
                                                    <span class="badge 
                                                        @(incident.Result switch
                                                        {
                                                            "รับแจ้ง" => "bg-secondary",
                                                            "ดำเนินการ" => "bg-warning",
                                                            "รอดำเนินการ" => "bg-info",
                                                            "แก้ไขแล้ว" => "bg-success",
                                                            "ปิดเรื่อง" => "bg-dark",
                                                            _ => "bg-secondary"
                                                        })">
                                                        @incident.Result
                                                    </span>
                                                </td>
                                                <td>
                                                    <a href="@Url.Action("Details", "Home", new { id = incident.IncidentId })" class="btn btn-sm btn-primary" title="ดูรายละเอียด">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a href="@Url.Action("Edit", "Home", new { id = incident.IncidentId })" class="btn btn-sm btn-warning" title="แก้ไข">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a href="@Url.Action("Delete", "Home", new { id = incident.IncidentId })" class="btn btn-sm btn-danger" title="ลบ">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center py-4">
                                                <i class="bi bi-inbox fs-1 text-muted"></i>
                                                <p class="text-muted mt-2">ไม่พบข้อมูลเหตุการณ์ในระบบ</p>
                                                <p class="text-muted">กรุณาเริ่มต้นเพื่อสร้างเหตุการณ์ใหม่</p>
                                                <a href="@Url.Action("Create", "Home")" class="btn btn-primary mt-2">
                                                    <i class="bi bi-plus-circle"></i> สร้างเหตุการณ์ใหม่
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        @if (Model != null && Model.Any())
                        {
                            <nav aria-label="Page navigation">
                                <ul class="pagination justify-content-center">
                                    @if (currentPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("Index", "Home", new { page = currentPage - 1, search = ViewData["Search"], statusFilter = statusFilter, serviceTypeFilter = serviceTypeFilter })">ก่อนหน้า</a>
                                        </li>
                                    }

                                    @for (int i = 1; i <= totalPages; i++)
                                    {
                                        <li class="page-item @(i == currentPage ? "active" : "")">
                                            <a class="page-link" href="@Url.Action("Index", "Home", new { page = i, search = ViewData["Search"], statusFilter = statusFilter, serviceTypeFilter = serviceTypeFilter })">@i</a>
                                        </li>
                                    }

                                    @if (currentPage < totalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("Index", "Home", new { page = currentPage + 1, search = ViewData["Search"], statusFilter = statusFilter, serviceTypeFilter = serviceTypeFilter })">ถัดไป</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
