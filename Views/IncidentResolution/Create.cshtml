@model DOTNETCORE_DEV.Models.IncidentResolution
@{
    ViewData["Title"] = "บันทึกการแก้ไขปัญหา";
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-shield-exclamation"></i>
                ระบบจัดการเหตุการณ์ - ก.ล.ต.
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-list-ul"></i> รายการเหตุการณ์
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-tools"></i> บันทึกการแก้ไขปัญหา
                        </h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Create" method="post">
                            <input type="hidden" asp-for="IncidentId" />
                            
                            <div class="row mb-3">
                                <div class="col-12">
                                    <h6 class="text-primary"><i class="bi bi-gear"></i> ข้อมูลการแก้ไข</h6>
                                    <hr>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Component ที่เกิดปัญหา <span class="text-danger">*</span></label>
                                    <select class="form-select" asp-for="Component" required>
                                        <option value="">-- เลือก Component --</option>
                                        <option value="Server">Server</option>
                                        <option value="Hardware">Hardware</option>
                                        <option value="Software สำเร็จรูป">Software สำเร็จรูป</option>
                                        <option value="ระบบ Application">ระบบ Application</option>
                                    </select>
                                    <span asp-validation-for="Component" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">วันที่คาดว่าจะเริ่มแก้ไข <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" asp-for="EstimatedStartDate" required />
                                    <span asp-validation-for="EstimatedStartDate" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">วันที่คาดว่าจะเสร็จ <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" asp-for="EstimatedEndDate" required />
                                    <span asp-validation-for="EstimatedEndDate" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">วันที่แก้ไขแล้วเสร็จ</label>
                                    <input type="date" class="form-control" asp-for="ActualCompletionDate" />
                                    <span asp-validation-for="ActualCompletionDate" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">รายละเอียดการแก้ไข <span class="text-danger">*</span></label>
                                    <textarea class="form-control" asp-for="ResolutionDetails" rows="4" required placeholder="กรุณากรอกรายละเอียดการแก้ไขปัญหา..."></textarea>
                                    <span asp-validation-for="ResolutionDetails" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="row">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between">
                                        <a href="@Url.Action("Index", new { incidentId = Model.IncidentId })" class="btn btn-secondary">
                                            <i class="bi bi-arrow-left"></i> ยกเลิก
                                        </a>
                                        <div>
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-check-circle"></i> บันทึก
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>