@model List<IncidentResolution>

<h2>ประวัติการแก้ไขปัญหา</h2>
<table border="1">
    <tr>
        <th>Component</th>
        <th>รายละเอียดการแก้ไข</th>
        <th>วันที่คาดว่าจะเริ่ม</th>
        <th>วันที่คาดว่าเสร็จ</th>
        <th>วันที่เสร็จจริง</th>
        <th>ชั่วโมงที่ใช้</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Component</td>
            <td>@item.ResolutionDetails</td>
            <td>@item.EstimatedStartDate.ToShortDateString()</td>
            <td>@item.EstimatedEndDate.ToShortDateString()</td>
            <td>@item.ActualCompletionDate?.ToShortDateString()</td>
            <td>@item.HoursSpent</td>
        </tr>
    }
</table>