@{
    ViewBag.Title = "Assign Incident";
}
<h2>Assign Incident</h2>

@if (ViewBag.Error != null)
{
    <p style="color: red;">@ViewBag.Error</p>
}

@if (ViewBag.Success != null)
{
    <p style="color: green;">@ViewBag.Success</p>
}

<form method="post" action="/AssignIncident/Assign">
    <label>Incident:</label>
    <select name="incidentId">
        @foreach (var incident in ViewBag.Incidents)
        {
            <option value="@incident.IncidentId">@incident.Problem</option>
        }
    </select>

    <label>Assigned By:</label>
    <select name="assignedById">
        @foreach (var emp in ViewBag.Employees)
        {
            <option value="@emp.EmployeeID">@emp.Name (Level @emp.SupportLevel)</option>
        }
    </select>

    <label>Assign To:</label>
    <select name="assignedToId">
        @foreach (var emp in ViewBag.Employees)
        {
            <option value="@emp.EmployeeID">@emp.Name (Level @emp.SupportLevel)</option>
        }
    </select>

    <button type="submit">Assign</button>
</form>

<h3>Incident History</h3>
<ul>
    @foreach (var incident in ViewBag.Incidents)
    {
        <li>
            <a asp-controller="AssignIncident" asp-action="History" asp-route-incidentId="@incident.IncidentId">
                @incident.Problem
            </a>
        </li>
    }
</ul>
