@{
    ViewData["Title"] = "Test Data";
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <h1>ข้อมูลทดสอบในระบบ</h1>
        
        <div class="row">
            <div class="col-md-4">
                <h3>Incidents (@ViewBag.Incidents?.Count ?? 0)</h3>
                @if (ViewBag.Incidents != null)
                {
                    <ul>
                        @foreach (var incident in ViewBag.Incidents)
                        {
                            <li>ID: @incident.IncidentId - @incident.Problem</li>
                        }
                    </ul>
                }
            </div>
            
            <div class="col-md-4">
                <h3>Employees (@ViewBag.Employees?.Count ?? 0)</h3>
                @if (ViewBag.Employees != null)
                {
                    <ul>
                        @foreach (var employee in ViewBag.Employees)
                        {
                            <li>ID: @employee.EmployeeID - @employee.Name (Level: @employee.SupportLevel)</li>
                        }
                    </ul>
                }
            </div>
            
            <div class="col-md-4">
                <h3>Assignments (@ViewBag.Assignments?.Count ?? 0)</h3>
                @if (ViewBag.Assignments != null)
                {
                    <ul>
                        @foreach (var assignment in ViewBag.Assignments)
                        {
                            <li>
                                ID: @assignment.AssignmentId - 
                                Status: @assignment.AssignmentStatus - 
                                Incident: @assignment.Incident?.Problem
                                <br>
                                <a href="/AssignmentResolution/Index/@assignment.AssignmentId" class="btn btn-sm btn-primary">View Resolution</a>
                                <a href="/AssignmentResolution/Create/@assignment.AssignmentId" class="btn btn-sm btn-info">Create Resolution</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
        
        <div class="mt-4">
            <a href="/Test/CreateTestAssignment" class="btn btn-success">สร้าง Assignment ทดสอบ</a>
            <a href="/Home/Index" class="btn btn-secondary">กลับหน้าแรก</a>
        </div>
    </div>
</body>
</html>
