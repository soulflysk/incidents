@{
    ViewData["Title"] = "Create Test Assignment";
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <h1>สร้างข้อมูลทดสอบ</h1>
        
        <div class="alert alert-info">
            @ViewBag.Message
        </div>
        
        @if (ViewBag.AssignmentId != null)
        {
            <div class="mt-3">
                <h3>ทดสอบการเข้าถึง AssignmentResolution:</h3>
                <a href="/AssignmentResolution/Index/@ViewBag.AssignmentId" class="btn btn-primary me-2">Index Page</a>
                <a href="/AssignmentResolution/Create/@ViewBag.AssignmentId" class="btn btn-info me-2">Create Page</a>
            </div>
        }
        
        <div class="mt-4">
            <a href="/Test/Index" class="btn btn-secondary">กลับ</a>
            <a href="/Home/Index" class="btn btn-primary">หน้าแรก</a>
        </div>
    </div>
</body>
</html>
