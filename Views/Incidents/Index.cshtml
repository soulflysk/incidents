@model IEnumerable<Incident>

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Incident List</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Incidents" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>&nbsp; Create New Incident
            </a>
        </div>
    </div>
    <br /><br />

    @if (Model.Count() > 0)
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>
                        Problem
                    </th>
                    <th>
                        Date
                    </th>
                    <th>
                        Result
                    </th>
                    <th>
                        Inside Or Outside
                    </th>
                    <th>

                    </th>
                    <th>

                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model)
                {
                    <tr>
                        <td width="30%">
                            @obj.Problem
                        </td>
                        <td width="30%">
                            @obj.Date
                        </td>
                        <td width="20%">
                            @obj.Result
                        </td>
                        <td width="30%">
                            @obj.InsideOrOutside
                        </td>
                        <td>
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Incidents" asp-action="Edit" asp-route-id="@obj.IncidentId"
                                    class="btn btn-primary mx-2"><i class="bi bi-pencil-square"></i> Edit</a>
                                <a asp-controller="Incidents" asp-action="Delete" asp-route-id="@obj.IncidentId"
                                    class="btn btn-danger mx-2"><i class="bi bi-trash-fill"></i> Delete</a>
                            </div>
                        </td>
                        <td>
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Incidents" asp-action="Details" asp-route-id="@obj.IncidentId"
                                    class="btn btn-primary mx-2">Details</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    else{
        <div class="alert alert-secondary">ไม่มีข้อมูลในระบบ</div>
    }

</div>