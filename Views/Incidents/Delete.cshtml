@model Incident
<form method="post" asp-action="Delete">
    <input asp-for="IncidentId" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Delete Incident</h2>
            <hr/>
        </div>
        @*<div asp-validation-summary="All"></div>*@
        <div class="mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="EmployeeId"></label>
            <input asp-for="EmployeeId" disabled class="form-control" />
        </div>
        <button type="submit" class="btn btn-danger" style="width:150px">Delete</button>
        <a asp_controller="Category" asp-action="Index" class="btn btn-secondary" style="width:150px"
        onclick="return confirm('คุณต้องการย้อนกลับไปหรือไม่?')">
            Back to List
        </a>
    </div>
</form>
@section Scripts{
    @{
    <partial name="_ValidationScriptsPartial" />
}
}
